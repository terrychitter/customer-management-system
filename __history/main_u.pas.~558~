function TfrmMain.retreiveAccountNum(list: TListBox): integer;
begin

  // Getting the account number and returning it
  Result := StrToInt(Trim(Copy(list.Items[list.ItemIndex], 1,
    pos(#9, list.Items[list.ItemIndex]))));

end;

procedure TfrmMain.saveToDB;
var
  tempFile: Textfile;
begin

  // Saving all fields to the database;
  customer.setTitle(edt_tbsCustomers_title.Text);
  customer.setInitial(edt_tbsCustomers_name.Text[1]);
  customer.setName(edt_tbsCustomers_name.Text);
  customer.setSurname(edt_tbsCustomers_surname.Text);
  customer.setHouseNo(edt_tbsCustomers_housenumber.Text);
  customer.setStreet(edt_tbsCustomers_streetname.Text);
  customer.setSuburb(edt_tbsCustomers_suburb.Text);
  customer.setPostal(StrToInt(edt_tbsCustomers_postal.Text));
  customer.setPhone(edt_tbsCustomers_phonenumber.Text);
  customer.setEmail(edt_tbsCustomers_email.Text);
  customer.setOrigin(edt_tbsCustomers_origin.Text);

  // Adding comments to the comment's file
  AssignFile(tempFile, GetCurrentDir + '\datafiles\comments\' +
    IntToStr(customer.getAccNo) + '.txt');
  Rewrite(tempFile);
  Write(tempFile, red_tbsCustomers_comments.Text);
  CloseFile(tempFile);

  customer.setFrequency(StrToInt(edt_tbsCustomers_frequency.Text));
  customer.setNoBins(StrToInt(edt_tbsCustomers_nobins.Text));
  customer.setDay(cmb_tbsCustomers_days.Items[cmb_tbsCustomers_days.ItemIndex]);
  customer.setMonthly(StrToInt(edt_tbsCustomers_price.Text));

  if lbl_tbsCustomers_active.Caption = 'Active' then
    customer.setAccStatus(True)
  else
    customer.setAccStatus(False);

end;

procedure TfrmMain.searchAccount(searchbox: TEdit; radiogroup: TRadioGroup;
  listbox: TListBox);
var
  field: string;
begin

  listbox.Enabled := True;
  listbox.Items.Clear;

  // Showing all customers related to the search

  case radiogroup.ItemIndex of
    0:
      field := 'Acc_No';
    1:
      field := 'Surname';
    2:
      field := 'Street_name';
  end;

  if searchbox.Text = '' then
    popSearchList(listbox)
  else if dmTKServices.adoCustomers.Locate(field, searchbox.Text,
    [loPartialKey, loCaseInsensitive]) then
  begin
    displayCustomers(searchbox.Text, field, listbox, radiogroup);
  end
  else
  begin
    listbox.Items.Clear;
    listbox.Items.Add('No Results for ''' + searchbox.Text + '''');
    listbox.Enabled := False;
  end;
end;

