function TfrmMain.getBfAmount(account, month, year: integer): integer;
var
  prevBalance, diffInMonths: integer;
begin

  { ShowMessage('Account: ' + IntToStr(account) + #13 + 'Month: ' +
    IntToStr(month) + #13 + 'Year: ' + IntToStr(year)); }

  // Returning the customers bbf amount of the previous month or year
  with dmTKServices do
  begin
    adoPayments.Filtered := False;
    if month > 1 then
    begin
      adoPayments.Filter := 'Acc_no=' + IntToStr(account) + ' AND Date>=#' +
        IntToStr(year) + '/' + IntToStr(month - 1) + '/1# AND Date<=#' +
        IntToStr(year) + '/' + IntToStr(month - 1) + '/' +
        IntToStr(DayOf(EndOfAMonth(year, month - 1))) + '#';
      // ShowMessage(adoPayments.Filter);
    end
    else if month = 1 then
    begin
      adoPayments.Filter := 'Acc_no=' + IntToStr(account) + ' AND Date>=#' +
        IntToStr(year - 1) + '/' + IntToStr(12) + '/1# AND Date<=#' +
        IntToStr(year - 1) + '/' + IntToStr(12) + '/' +
        IntToStr(DayOf(EndOfAMonth(year - 1, 12))) + '#';
      // ShowMessage(adoPayments.Filter);
    end;

    adoPayments.Filtered := True;
    adoPayments.Sort := 'Date DESC';
    adoPayments.First;

    // ShowMessage('Record count: ' + IntToStr(adoPayments.RecordCount));

    if adoPayments.RecordCount = 0 then
    begin
      // ShowMessage('Balance is set to zero');
      prevBalance := 0;

      // Checking if there is any payments at all
      adoPayments.Filtered := False;
      adoPayments.Filter := 'Acc_no=' + IntToStr(account);
      adoPayments.Sort := 'Date DESC';
      adoPayments.First;

      if adoPayments.RecordCount > 0 then
      begin
        // First working out the fee date if the user has not paid the previous month/s
        diffInMonths :=
          Round(MonthSpan(StrToDate(IntToStr(year) + '/' + IntToStr(month) +
          '/1'), adoPayments['Date']));
        // ShowMessage('Difference in months: ' + IntToStr(diffInMonths));
        adoCustomers.Locate('Acc_No', account, []);

        if adoCustomers['Active'] then
        begin
          prevBalance := adoPayments['Balance_bf'] +
            ((diffInMonths - 1) * adoCustomers['Monthly_payable']);
          // ShowMessage('adding difference')
        end
        else
        begin
          prevBalance := adoPayments['Balance_bf'];
          // ShowMessage('not adding difference')
        end;
      end;
    end
    else
    begin
      // ShowMessage('Balance is taken from db');
      prevBalance := adoPayments['Balance_bf'];
    end;

    adoPayments.Filtered := False;
    // ShowMessage(IntToStr(prevBalance));
    Result := prevBalance;

