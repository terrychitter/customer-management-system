procedure TfrmMain.loadCustomer(customer: TCustomer);
var
  tempFile: Textfile;
  line: string;
begin

  // Loading customer details into the ui
  edt_tbsCustomers_title.Text := customer.getTitle;
  edt_tbsCustomers_initial.Text := customer.getInitial;
  edt_tbsCustomers_name.Text := customer.getName;
  edt_tbsCustomers_surname.Text := customer.getSurname;
  edt_tbsCustomers_email.Text := customer.getEmail;
  edt_tbsCustomers_housenumber.Text := customer.getHouseNo;
  edt_tbsCustomers_streetname.Text := customer.getStreet;
  edt_tbsCustomers_suburb.Text := customer.getSuburb;
  edt_tbsCustomers_postal.Text := IntToStr(customer.getPostal);
  edt_tbsCustomers_phonenumber.Text := customer.getPhone;
  edt_tbsCustomers_origin.Text := customer.getOrigin;
  edt_tbsCustomers_frequency.Text := IntToStr(customer.getFrequency);
  edt_tbsCustomers_nobins.Text := IntToStr(customer.getnoBins);
  cmb_tbsCustomers_days.Text := customer.getDay;
  edt_tbsCustomers_price.Text := IntToStr(customer.getMonthly);
  red_tbsCustomers_comments.Clear;

  // Getting comments
  AssignFile(tempFile, GetCurrentDir + '\datafiles\comments\' +
    IntToStr(customer.getAccNo) + '.txt');
  Reset(tempFile);
  while not Eof(tempFile) do
  begin
    Readln(tempFile, line);
    red_tbsCustomers_comments.Lines.Add(line);
  end;

  CloseFile(tempFile);

  if customer.getaccStatus then
  begin
    shp_tbsCustomers_active.Brush.Color := clMoneyGreen;
    lbl_tbsCustomers_active.Caption := 'Active';
  end
  else
  begin
    shp_tbsCustomers_active.Brush.Color := clRed;
    lbl_tbsCustomers_active.Caption := 'Inactive';
  end;

  // Loading payments into the dbgrid
  dbg_tbsCustomers_payments.DataSource := dmTKServices.dsOutput;
  with dmTKServices.adoPayments do
  begin
    Filtered := False;
    Filter := 'Acc_no = ' + IntToStr(customer.getAccNo);
    Filtered := True;
    Sort := 'Date DESC';
    tfloatfield(dbg_tbsCustomers_payments.DataSource.dataset.fieldbyname
      ('Amount')).Displayformat := 'R0.00';
    tfloatfield(dbg_tbsCustomers_payments.DataSource.dataset.fieldbyname
      ('Balance_bf')).Displayformat := 'R0.00';
  end;

  // Updating status bar and enabling group box
  grp_tbsCustomers_customer.Enabled := True;

  // Entering edit mode
  if editing then
    enterEditMode(True)
  else
    enterEditMode(False);

end;

