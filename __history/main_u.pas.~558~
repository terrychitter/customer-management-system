function TfrmMain.paymentMonthAndYearPresent(account: integer;
  date: TDateTimePicker): boolean;
var
  month, year: integer;
begin

  // Determining if there is already a month and year for the payment

  // Retrieving month and year
  month := MonthOf(date.date);
  year := YearOf(date.date);
  // ShowMessage('Month: ' + IntToStr(month) + #13 + 'Year: ' + IntToStr(year));

  // Searching for month and year in the payments table
  with dmTKServices do
  begin
    adoPayments.Open;
    adoPayments.Filter := '';
    adoPayments.Filtered := False;
    adoPayments.Filter := 'Acc_No=' + IntToStr(account) + ' AND Date >=#' +
      IntToStr(year) + '/' + IntToStr(month) + '/1# AND Date <=#' +
      IntToStr(year) + '/' + IntToStr(month) + '/' +
      IntToStr(DayOf(EndOfAMonth(StrToInt(IntToStr(year)),
      StrToInt(IntToStr(month))))) + '#';
    adoPayments.Filtered := True;
    // ShowMessage(adoPayments.Filter);
    if adoPayments.RecordCount > 0 then
    begin
      adoPayments.Filtered := False;
      Result := True;
    end
    else
    begin
      adoPayments.Filtered := False;
      Result := False;
    end;
  end;

  openPaymentState(activePayment);

end;

