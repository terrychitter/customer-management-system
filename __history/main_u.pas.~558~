procedure TfrmMain.addPayment(account: integer; date: TDate; amount: integer;
  pay_type: string; newOrExisting: string);
var
  month, year, prevBalance, feeAmount, diffInMonths: integer;
begin

  with dmTKServices do
  begin
    adoPayments.Filtered := False;
    adoCustomers.Locate('Acc_no', activePayment, []);

    if newOrExisting = 'existing' then
    begin
      // Adding a payment to a month that already has a payment
      month := MonthOf(date);
      year := YearOf(date);

      // Sorting and filtering the records so that it may add the balance correctly
      adoPayments.Filter := 'Acc_No=' + IntToStr(account) + ' AND Date >=#' +
        IntToStr(year) + '/' + IntToStr(month) + '/1# AND Date <=#' +
        IntToStr(year) + '/' + IntToStr(month) + '/' +
        IntToStr(DayOf(EndOfAMonth(StrToInt(IntToStr(year)),
        StrToInt(IntToStr(month))))) + '#';
      adoPayments.Filtered := True;
      adoPayments.Sort := 'Date DESC';

      // Getting balance from previous month
      adoPayments.First;
      prevBalance := adoPayments['Balance_bf'];

      // Adding a new payment
      adoPayments.Insert;
      adoPayments['Acc_No'] := activePayment;
      adoPayments['Date'] := date;
      adoPayments['Amount'] := amount;
      adoPayments['Payment_type'] := pay_type;
      adoPayments['Balance_bf'] := prevBalance - amount;
      adoPayments.Post;
      adoPayments.Filtered := False;
    end
    else
    begin
      diffInMonths := 1;
      adoPayments.Filter := 'Acc_No=' + IntToStr(account);
      adoPayments.Filtered := True;
      adoPayments.Sort := 'Date DESC';
      adoPayments.First;

      // Getting previous balance and fee
      if adoPayments.RecordCount = 0 then
        prevBalance := 0
      else
      begin
        prevBalance := adoPayments['Balance_bf'];

        // First working out the fee amount if the user has not paid the previous month/s
        diffInMonths := Round(MonthSpan(date, adoPayments['Date']));
        // ShowMessage('Difference in months: ' + IntToStr(diffInMonths));
      end;

      // Getting fee of the account
      feeAmount := adoCustomers['Monthly_payable'];

      // Adding a new payment
      adoPayments.Insert;
      adoPayments['Acc_No'] := activePayment;
      adoPayments['Date'] := date;
      adoPayments['Amount'] := amount;
      adoPayments['Payment_type'] := pay_type;

      // Working out the difference depending on whether the customer is active or not
      if adoCustomers['Active'] then
        adoPayments['Balance_bf'] := prevBalance - amount +
          (diffInMonths * feeAmount)
      else
        adoPayments['Balance_bf'] := prevBalance - amount;

      adoPayments.Post;
      adoPayments.Filtered := False;
    end;
  end;

  // Loading the customer in the payment sheet again
  openPaymentState(account);

end;

procedure TfrmMain.addToSelectedList(account: integer; option: string);
var
  tempAccNum, i { loop variable } : integer;
begin

  lst_tbsInvoices_selected.TabWidth := 20;

  // Making sure the same customer is not added twice or more
  if lst_tbsInvoices_selected.Items.Count <> 0 then
  begin
    for i := 0 to lst_tbsInvoices_selected.Items.Count do
    begin
      // Retrieving the account number of the active item and comparing it with the account parameter
      { ShowMessage('i: ' + IntToStr(i) + #13 + 'Count: ' +
        IntToStr(lst_tbsInvoices_selected.Items.Count) + #13 + 'Item Index: ' +
        IntToStr(lst_tbsInvoices_selected.ItemIndex)); }

      lst_tbsInvoices_selected.ItemIndex := i;

      tempAccNum := retreiveAccountNum(lst_tbsInvoices_selected);
      if tempAccNum = account then
      begin
        if option <> 'selectAll' then
          ShowMessage('This account is already selected');
        Exit;
      end;
    end;
  end;

  // Adding an account to the selected list
  with dmTKServices do
  begin
    adoCustomers.Locate('Acc_no', account, []);
    lst_tbsInvoices_selected.Items.Add(IntToStr(adoCustomers['Acc_no']) + #9 +
      adoCustomers['Surname'] + ' ' + adoCustomers['Initial'] + '.' + #9 +
      adoCustomers['Street_name'] + #9 + adoCustomers['Suburb']);
  end;

  lst_tbsInvoices_selected.ItemIndex := -1;

end;

procedure TfrmMain.chk_tbsInvoices_selectAllClick(Sender: TObject);
begin

  // Adding all customers to the list (only adding active customers)
  if chk_tbsInvoices_selectAll.Checked = True then
  begin
    with dmTKServices do
    begin
      adoCustomers.Filtered := False;
      adoCustomers.Filter := 'Active=true';
      adoCustomers.Filtered := True;
      adoCustomers.First;

      while not adoCustomers.Eof do
      begin
        addToSelectedList(adoCustomers['Acc_no'], 'selectAll');
        adoCustomers.Next;
      end;
    end;
  end
  else
    lst_tbsInvoices_selected.Clear;

  dmTKServices.adoCustomers.Filter := '';
  dmTKServices.adoCustomers.Filtered := False;

  lst_tbsInvoices_selected.OnClick(self);

end;

