procedure TfrmMain.popSearchList(list: TListBox);
begin

  list.Items.Clear;
  list.TabWidth := 35;

  // Populating the search list with all customers in the format: Surname, Initial, Street Name)
  with dmTKServices do
  begin
    adoCustomers.Open;
    adoCustomers.Filtered := False;
    adoCustomers.First;

    while not adoCustomers.Eof do
    begin
      list.Items.Add(IntToStr(adoCustomers['Acc_No']) + #9 + adoCustomers
        ['Surname'] + #9 + adoCustomers['Initial'] + '.' + #9 + adoCustomers
        ['Street_name']);
      adoCustomers.Next;
    end;

  end;

end;

