procedure TfrmMain.displayCustomers(key, field: string; listbox: TListBox;
  radiogroup: TRadioGroup);
begin

  // Displaying all customers pertaining to the criteria
  with dmTKServices do
  begin

    // Displaying different queries for different data types
    adoQry.Close;
    case radiogroup.ItemIndex of
      0:
        adoQry.SQL.Text :=
          'SELECT Acc_no, Surname, Initial, Street_name FROM Customers WHERE Acc_no='
          + key;
      1 .. 2:
        adoQry.SQL.Text :=
          'SELECT Acc_no, Surname, Initial, Street_name FROM Customers WHERE ' +
          field + ' like "' + Uppercase(key) + '%"';
    end;
    adoQry.Open;

    adoQry.First;
    while not adoQry.Eof do
    begin
      listbox.Items.Add(IntToStr(adoQry['Acc_No']) + #9 + adoQry['Surname'] + #9
        + adoQry['Initial'] + '.' + #9 + adoQry['Street_name']);
      adoQry.Next;
    end;
  end;

end;

