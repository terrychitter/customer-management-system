procedure TfrmAddNewCustomer.AddCustomerToDB;
var
  preAccNo, tempAccNo: Integer;
  tempFile: TextFile;
begin

  // Adding the new customer to the database

  with dmTKServices do
  begin

    // Generating new customer ID
    adoCustomers.Sort := 'Acc_no DESC';
    adoCustomers.First;
    preAccNo := adoCustomers['Acc_no'];
    tempAccNo := preAccNo + 1;

    adoCustomers.Insert;
    adoCustomers['Acc_no'] := tempAccNo;
    adoCustomers['Title'] := cmbTitle.Items[cmbTitle.ItemIndex];
    adoCustomers['Initial'] := edtName.Text[1];
    adoCustomers['Name'] := edtName.Text;
    adoCustomers['Surname'] := edtSurname.Text;
    adoCustomers['Home_no'] := edtNumber.Text;
    adoCustomers['Street_name'] := edtStreet.Text;
    adoCustomers['Suburb'] := edtSuburb.Text;
    adoCustomers['Postal'] := StrToInt(edtPostal.Text);
    adoCustomers['Active'] := True;
    adoCustomers['Phone_no'] := edtPhone.Text;
    adoCustomers['Email'] := edtEmail.Text;
    adoCustomers['Origin'] := edtOrigin.Text;
    adoCustomers['Frequency'] := sedFrequency.value;
    adoCustomers['No_bins'] := sedNoBins.value;
    adoCustomers['Day'] := cmbDays.Items[cmbDays.ItemIndex];
    adoCustomers['Monthly_payable'] := StrToInt(edtMonthly.Text);
    adoCustomers.Post;
    adoCustomers.Refresh;

    //Creating customer comment's file
    AssignFile(tempFile, GetCurrentDir + '\datafiles\comments\' + IntToStr(tempAccNo) + '.txt');
    Rewrite(tempFile);
  end;

  if chkOpen.Checked then
    frmMain.activeCustomer := tempAccNo;

  frmMain.OnActivate(self);
  frmAddNewCustomer.Close;

end;

procedure TfrmAddNewCustomer.btnAddClick(Sender: TObject);
begin

  // Adding new customer to the database if all fields are valid
  if isValid then
  begin
    ShowMessage('Customers has been successfuly added');
    AddCustomerToDB;
  end;

end;

