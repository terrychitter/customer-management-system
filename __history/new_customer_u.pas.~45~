function TfrmAddNewCustomer.isCorrectLength(edit: TEdit; size: Integer)
  : boolean;
begin

  // Returning whether edit is the correct length (size)
  if Length(edit.Text) > size then
    Result := False
  else
    Result := True;

end;

function TfrmAddNewCustomer.isEmpty(edit: TEdit): boolean;
begin

  // Determining whether edit is empty
  if Length(edit.Text) = 0 then
    Result := True
  else
    Result := False;

end;

function TfrmAddNewCustomer.isFieldValid(combo: TComboBox;
  fieldName: string): boolean;
begin

  // Checking whether the field is empty
  if isEmpty(combo) then
  begin
    ShowMessage(fieldName + ' field is empty.');
    redify(True, combo);
    Result := False;
    Exit;
  end;

  Result := True;

end;

function TfrmAddNewCustomer.isFieldValid(Spin: TSpinEdit;
  fieldName: string): boolean;
begin

  // First checking whether the field is empty or whether it is a valid integer
  if isEmpty(Spin) then
  begin
    ShowMessage(fieldName + ' field can not be set to zero.');
    redify(True, Spin);
    Result := False;
    Exit;
  end;

  Result := True;

end;

function TfrmAddNewCustomer.isFieldValid(edit: TEdit; size: Integer;
  fieldName: string): boolean;
begin

  // First checking whether the field is empty then whether length is appropriate
  if isEmpty(edit) then
  begin
    ShowMessage(fieldName + ' field is empty.');
    redify(True, edit);
    Result := False;
    Exit;
  end;

  if Length(edit.Text) > size then
  begin
    ShowMessage(fieldName + ' field is too long. Max ' + IntToStr(size) +
      ' characters');
    redify(True, edit);
    Result := False;
    Exit;
  end;

  Result := True;

end;

function TfrmAddNewCustomer.isEmpty(combo: TComboBox): boolean;
begin

  // Determining whether combo box is empty
  if (combo.ItemIndex < 0) or (combo.Text = '') then
    Result := True
  else
    Result := False;

end;

function TfrmAddNewCustomer.isEmpty(Spin: TSpinEdit): boolean;
begin

  // Determining whether spin edit is empty
  if Spin.value <= 0 then
    Result := True
  else
    Result := False;

end;

function TfrmAddNewCustomer.isInteger(value: string): boolean;
var
  tempInt: Integer;
begin

  // Determing whether value is a valid integer
  if TryStrToInt(value, tempInt) then
    Result := True
  else
    Result := False;

end;

function TfrmAddNewCustomer.isValid: boolean;
begin

  // Validating all fields

  // Title
  if not isFieldValid(cmbTitle, 'Title') then
  begin
    Result := False;
    Exit;
  end;

  // Name --50
  if not isFieldValid(edtName, 50, 'Name') then
  begin
    Result := False;
    Exit;
  end;

  // Surname --50
  if not isFieldValid(edtSurname, 50, 'Surname') then
  begin
    Result := False;
    Exit;
  end;

  // Phone --15
  if not isFieldValid(edtPhone, 15, 'Phone Number') then
  begin
    Result := False;
    Exit;
  end;

  // Email --110
  if not isFieldValid(edtEmail, 110, 'Email Address') then
  begin
    Result := False;
    Exit;
  end;

  // Origin --50
  if not isFieldValid(edtOrigin, 50, 'Origin') then
  begin
    Result := False;
    Exit;
  end;

  // House Number --10
  if not isFieldValid(edtNumber, 10, 'House Number') then
  begin
    Result := False;
    Exit;
  end;

  // Street Name --60
  if not isFieldValid(edtStreet, 60, 'Street Name') then
  begin
    Result := False;
    Exit;
  end;

  // Suburb --50
  if not isFieldValid(edtSuburb, 50, 'Suburb') then
  begin
    Result := False;
    Exit;
  end;

  // Postal
  if not isFieldValid(edtPostal, 10, 'Postal') then
  begin
    Result := False;
    Exit;
  end;

  if not isInteger(edtPostal.Text) then
  begin
    ShowMessage('Postal Code field is not a number.');
    redify(True, edtPostal);
    Result := False;
    Exit;
  end;

  // Frequency
  if not isFieldValid(sedFrequency, 'Frequency') then
  begin
    Result := False;
    Exit;
  end;

  // No Bins
  if not isFieldValid(sedNoBins, 'No Bins') then
  begin
    Result := False;
    Exit;
  end;

  // Days
  if not isFieldValid(cmbDays, 'Day') then
  begin
    Result := False;
    Exit;
  end;

  // Monthly Fee
  if not isFieldValid(edtMonthly, 10, 'Monthly Fee') then
  begin
    Result := False;
    Exit;
  end;

  if not isInteger(edtMonthly.Text) then
  begin
    ShowMessage('Monthly Fee field is not a number.');
    Result := False;
    Exit;
  end;

  Result := True;

end;

procedure TfrmAddNewCustomer.redify(value: boolean; edit: TEdit);
begin

  // Redify the edit
  if value then
    edit.Color := clRed
  else
    edit.Color := clWhite;

  edit.SetFocus;

end;

