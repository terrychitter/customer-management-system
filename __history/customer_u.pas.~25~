procedure TCustomer.setAccNo(accNo: integer);
begin

  setAndLocateAdo;
  with dmTKServices do
  begin
    adoCustomers.Edit;
    adoCustomers['Acc_no'] := accNo;
    adoCustomers.Post;
  end;
  self.accNo := accNo;

end;

procedure TCustomer.setAccStatus(accStatus: boolean);
begin

  setAndLocateAdo;
  with dmTKServices do
  begin
    adoCustomers.Edit;
    adoCustomers['Active'] := accStatus;
    adoCustomers.Post;
  end;
  self.accStatus := accStatus;

end;

procedure TCustomer.setAndLocateAdo;
begin

  with dmTKServices.adoCustomers do
  begin
    Close;
    TableName := 'Customers';
    Open;
    Locate('Acc_no', self.accNo, []);
  end;

end;

