  self.accStatus := accStatus;
  self.email := email;
  self.houseNo := houseNo;
  self.street := street;
  self.suburb := suburb;
  self.postal := postal;
  self.phone := phone;
  self.origin := origin;
  self.frequency := frequency;
  self.noBins := noBins;
  self.day := day;
  self.monthly := monthly;
  self.accNo := accNo;
  self.currentBalance := currentBalance;
  self.comments := comments;

end;

