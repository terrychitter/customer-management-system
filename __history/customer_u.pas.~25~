    procedure setSuburb(suburb: string);
    procedure setPhone(phone: string);
    procedure setOrigin(origin: string);
    procedure setDay(day: string);
    procedure setHouseNo(houseNo: integer);
    procedure setPostal(postal: integer);
    procedure setFrequency(frequency: integer);
    procedure setNoBins(noBins: integer);
    procedure setMonthly(monthly: integer);
